{
  "manifest_version": 3,
  "name": "LLM Chat Client",
  "version": "1.0.0",
  "minimum_chrome_version": "102",
  "description": "A ChatGPT-like client for OpenAI-compatible LLM APIs (DeepSeek supported).",
  "permissions": ["storage"],
  "host_permissions": ["https://*/*"],
  "action": {
    "default_title": "Open LLM Chat",
    "default_popup": "opener.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
